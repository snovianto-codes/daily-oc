# Singapore area name (must match NEA 2-hour forecast area names)
AREA=Jurong West

# NewsAPI key — get free at newsapi.org
NEWS_API_KEY=your_newsapi_key_here

# Anthropic API key — get at console.anthropic.com
ANTHROPIC_API_KEY=your_anthropic_key_here

# Telegram bot token — get from @BotFather on Telegram
TELEGRAM_TOKEN=your_telegram_bot_token_here

# Your Telegram chat ID — get by messaging your bot and checking getUpdates
TELEGRAM_CHAT_ID=your_telegram_chat_id_here

# Optional: customize news topics
NEWS_KEYWORDS=AI agents OR Singapore tech OR Southeast Asia startup OR MAS fintech OR artificial intelligence
